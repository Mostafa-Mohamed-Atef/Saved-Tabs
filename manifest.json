{
    "manifest_version": 3,
    "name": "Saved Tabs",
    "version": "1.0.0",
    "description": "Save tabs locally and reopen them later.",
    "action": {
      "default_popup": "popup.html",
      "default_title": "Saved Tabs",
      "default_icon": {
        "16": "favicon.png"
      }
    },
    "icons": {
      "16": "favicon.png"
    },
    "permissions": [
      "tabs",
      "storage"
    ]
  }